rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.uid == "rgFo1YPQNDdJxyfRCiWFXETpJHB2";
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/admin/$(request.auth.uid))
      );
    }

    function isProtectedPayoutCollection(collectionId) {
      return collectionId == "vendor_ledger" ||
        collectionId == "vendor_balances" ||
        collectionId == "vendor_payout_batches";
    }

    // Gestion du profil admin
    match /admin/{userId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin() || (isAdmin() && request.auth.uid == userId);

      match /workSessions/{sessionId} {
        allow read, write: if isSuperAdmin() || (isAdmin() && request.auth.uid == userId);
      }
    }

    // Collections de paiement vendeur: lecture admin uniquement.
    // Les écritures passent par Cloud Functions/Admin SDK, qui bypass les règles Firestore.
    match /vendor_ledger/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /vendor_balances/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /vendor_payout_batches/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Toutes les collections metier (hors /admin) accessibles aux admins connectes.
    match /{collectionId}/{docId} {
      allow read: if isAdmin() && collectionId != "admin";
      allow write: if isAdmin() &&
        collectionId != "admin" &&
        !isProtectedPayoutCollection(collectionId);
    }

    match /{collectionId}/{docId}/{document=**} {
      allow read: if isAdmin() && collectionId != "admin";
      allow write: if isAdmin() &&
        collectionId != "admin" &&
        !isProtectedPayoutCollection(collectionId);
    }
  }
}
